window-decoration = true
window-padding-x = 10
window-padding-y = 10
macos-icon = xray
clipboard-read = ask


font-family = Cascadia-Code
background = 1F1F28
foreground = DDD8BB

shell-integration = zsh


keybind = global:super+§=toggle_quick_terminal
keybind = super+shift+/=new_split:right
keybind = super+shift+-=new_split:down
keybind = super+shift+z=toggle_split_zoom
keybind = super+shift+r=equalize_splits

keybind = super+shift+up=scroll_page_up

confirm-close-surface = false

desktop-notifications = true
keybind = shift+enter=text:\x1b\r


macos-window-buttons = hidden
macos-titlebar-proxy-icon = hidden
macos-window-shadow = true
macos-titlebar-style = transparent
unfocused-split-opacity = 0.5


shell-integration-features = ssh-env