[commit]
	gpgSign = true

[alias]
	ap = add -p
	st = status -sb
	pf = push --force-with-lease
	a = add
	d = diff --color-words --find-renames=10%
	dc = diff --cached --color-words --find-renames=10%
	ca = commit --amend
	r = rebase -m --strategy-option=rename-threshold=10 --strategy-option=find-renames=10%
	rc = -c core.editor=true rebase --continue
	rxo = rebase -X ours
	rxt = rebase -X theirs
	rxe = "!r() { git rebase --interactive --exec $@ }; r"
	diff-vim = difftool -t vimdiff -y
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --
	last = log -1 HEAD --stat
	list = "!r() { refbranch=$1 count=$2; git for-each-ref --sort=-committerdate refs/heads --format='%(refname:short)|%(HEAD)%(color:yellow)%(refname:short)|%(color:bold green)%(committerdate:relative)|%(color:blue)%(subject)|%(color:magenta)%(authorname)%(color:reset)' --color=always --count=${count:-20} | while read line; do branch=$(echo \"$line\" | awk 'BEGIN { FS = \"|\" }; { print $1 }' | tr -d '*'); ahead=$(git rev-list --count \"${refbranch:-origin/main}..${branch}\"); behind=$(git rev-list --count \"${branch}..${refbranch:-origin/main}\"); colorline=$(echo \"$line\" | sed 's/^[^|]*|//'); echo \"$ahead|$behind|$colorline\" | awk -F'|' -vOFS='|' '{$5=substr($5,1,70)}1' ; done | ( echo \"ahead|behind|branch|lastcommit|message|author\n\" && cat) | column -ts'|';}; r"
	fixup = "!git log -n 50 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git commit --fixup"
	llcom = diff --cached | llm "describe the changes in 1 sentence" | git commit -F -
	llmcom = "!r() { git diff --cached | llm -m gpt-5.4 'describe the changes in 1 sentence for a commit message. Be consise and try to infer the reason for the change. format should be \"feat/fix/chore(COMPONENT): MESSAGE\". ONE LINE only' | git commit -F -;}; r"
	llmcomsum = "!r() { git diff --cached | llm -m gpt-5.4 'describe the changes in 1 sentence for a commit message. Be consise and try to infer the reason for the change. format should be \"feat/fix/chore(COMPONENT): MESSAGE\". ONE LINE only';}; r"

[init]
	defaultBranch = main

[includeIf "gitdir:~/workspace/src/github.com/sanity-io/"]
	path = ~/.gitconfig-work


[url "ssh://git@github.com"]
	insteadOf = https://github.com

[push]
	autoSetupRemote = true
	autoSetupRemote = true

[branch]
	sort = -committerdate

[tag]
	sort = version:refname

[core]
	attributesfile = ~/.gitattributes
	excludesfile = ~/.gitignore
  pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    line-numbers = true

[merge]
    conflictStyle = zdiff3

[column]
	ui = auto

[delta]
	navigate = true  # use n and N to move between diff sections
	line-numbers = true

[diff]
	algorithm = histogram
	colorMoved = zebra
	mnemonicPrefix = true
	renames = true

[rerere]
	enabled = true
	autoupdate = true

[rebase]
	autosquash = true
	updaterefs = true
	autostash = true

[help]
	autocorrect = prompt

[push]
	default = simple
	autosetupremote = true
	followTags = true

[fetch]
	prune = true
	prunetags = true
	all = true

[pull]
	ff = only

[diff "sopsdiffer"]
	textconv = sops -d

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L
